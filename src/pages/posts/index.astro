---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="文章" description="博客文章入口">
  <main class="shell">
    <section class="hero">
      <p class="eyebrow">Posts</p>
      <h1>文章</h1>
      <p class="lede">旧文章入口已合并到归档页。</p>
    </section>
    <section class="post-list">
      <article class="post-card">
        <h2><a href="/archives/">查看全部文章</a></h2>
      </article>
    </section>
  </main>
</BaseLayout>
