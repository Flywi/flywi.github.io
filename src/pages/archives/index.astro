---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="归档" description="WANGJINXIN 的博客文章归档">
  <main class="shell">
    <section class="hero">
      <p class="eyebrow">Archives</p>
      <h1>文章归档</h1>
      <p class="lede">旧文章不多，但每一篇都带着当时折腾服务器和工具链的现场感。</p>
    </section>
    <section class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <div class="meta">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
          </div>
          <h2><a href={post.data.legacyPath}>{post.data.title}</a></h2>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
