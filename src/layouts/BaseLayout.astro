---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'WANGJINXIN';
const { title = siteName, description = '个人博客，记录技术、服务器和一点日常折腾。' } = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/atom+xml" title={siteName} href="/atom.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="shell nav" aria-label="主导航">
        <a class="brand" href="/">WANG<span>JINXIN</span></a>
        <div class="nav-links">
          <a href="/archives/">归档</a>
          <a href="/2020/">相册</a>
          <a href="/about/">关于</a>
          <a href="/atom.xml">RSS</a>
        </div>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="shell">© {new Date().getFullYear()} WANGJINXIN. Powered by Astro.</div>
    </footer>
  </body>
</html>
